# Database
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require&schema=nexus

# Authentication
JWT_SECRET=your-jwt-secret-here
NEXUS_ADMIN_USER=admin@your-domain.com
NEXUS_ADMIN_PASSWORD=your-admin-password

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Your App <noreply@your-domain.com>
ADMIN_EMAIL=admin@your-domain.com

# AI Services
GOOGLE_API_KEY=your-google-key
GROQ_API_KEY=gsk_xxxxxxxxxxxx
GEMINI_API_KEY=your-gemini-key

# App Domain (for redirect middleware)
APP_DOMAIN=healthezee.com
DEV_APP_DOMAIN=dev.healthezee.com

# ABDM (Ayushman Bharat)
ABDM_CLIENT_ID=SBXID_xxxxxx
ABDM_CLIENT_SECRET=your-abdm-secret
ABDM_GATEWAY_URL=https://dev.abdm.gov.in/gateway
ABDM_HIP_ID=HIMS_XX_01

# Analytics
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# Vite (Frontend)
VITE_API_BASE_URL=http://localhost:4000

# Mobile APK signing (optional - only needed for release builds)
KEY_ALIAS=healthezee
KEY_PASSWORD=
STORE_FILE=healthezee-release.jks
STORE_PASSWORD=
